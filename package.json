{
  "name": "memoryblox",
  "private": true,
  "description": "Browser-based MEMORYBLOX remake built with TypeScript, HTML, and CSS.",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "artifacts": "npm run audio:index && npm run icons:sync",
    "validate": "npm run artifacts && markdownlint . && npm run lint && npm run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "quality:sanity": "npm run validate && npm run test",
    "quality:full": "npm run validate && npm run test && npm run test:e2e",
    "audio:index": "node ./tools/generate-audio-indexes.mjs",
    "icons:sync": "node ./tools/sync-icon-artifacts.mjs",
    "icons:generate-packs": "tsx ./tools/generate-icon-packs.ts --config ./config/icon-pack-generator.json",
    "leaderboard:server": "node ./tools/leaderboard-server.mjs",
    "serve:dev-root": "vite --port 8080",
    "dev": "concurrently -n Vite,Leaderboard -c blue,magenta \"vite\" \"npm run leaderboard:server\"",
    "dev:full": "npm run dev",
    "serve": "concurrently -k -n Vite,Leaderboard -c green,magenta \"vite preview --port 8080\" \"npm run leaderboard:server\"",
    "build": "npm run artifacts && vite build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "markdownlint-cli": "^0.48.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
